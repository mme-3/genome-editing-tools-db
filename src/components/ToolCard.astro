---
import type { Tool } from '../lib/schema';

interface Props {
  tool: Tool;
}

const { tool } = Astro.props;
const base = import.meta.env.BASE_URL;
const statusClass = `badge-status-${tool.maintenance_status.toLowerCase()}`;

const searchable = [tool.name, ...tool.aka, ...tool.tags, tool.publication?.title ?? '']
  .join(' ')
  .toLowerCase();
---

<article
  class="tool-card"
  data-id={tool.id}
  data-search={searchable}
  data-category={tool.category}
  data-secondary={tool.secondary_categories.join('|')}
  data-editors={tool.supported_editors.join('|')}
  data-platform={tool.platform.join('|')}
  data-license={tool.license ?? ''}
  data-maintenance={tool.maintenance_status}
  data-ai={String(tool.ai_enabled)}
>
  <div class="tool-card-head">
    <label class="compare-toggle">
      <input type="checkbox" class="compare-checkbox" data-id={tool.id} data-name={tool.name} />
      <span class="sr-only">Add {tool.name} to comparison</span>
    </label>
    <h3><a href={`${base}tools/${tool.id}/`}>{tool.name}</a></h3>
    <span class={`badge ${statusClass}`}>{tool.maintenance_status}</span>
  </div>
  <p class="tool-card-category">{tool.category}</p>
  <p class="tool-card-desc">{tool.description}</p>
  <div class="tool-card-tags">
    {tool.tags.slice(0, 5).map((tag) => <span class="tag">{tag}</span>)}
  </div>
</article>

<style>
  .tool-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .tool-card[hidden] {
    display: none;
  }
  .tool-card-head {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .tool-card-head h3 {
    margin: 0;
    font-size: 1rem;
    flex: 1;
  }
  .tool-card-category {
    margin: 0;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }
  .tool-card-desc {
    margin: 0;
    font-size: 0.9rem;
  }
  .tool-card-tags {
    margin-top: 0.25rem;
  }
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    overflow: hidden;
    clip: rect(0 0 0 0);
  }
</style>

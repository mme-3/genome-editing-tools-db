---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'A reference database of computational genome editing tools.' } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title} · Genome Editing Tools</title>
    <link rel="icon" href={`${base}favicon.svg`} />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <nav>
          <a class="brand" href={base}>Genome Editing Tools</a>
          <a href={`${base}tools/`}>Browse</a>
          <a href={`${base}workflow/`}>Workflow</a>
          <a href={`${base}timeline/`}>Timeline</a>
          <a href={`${base}compare/`}>Compare</a>
          <a href={`${base}start-here/`}>Start Here</a>
        </nav>
      </div>
    </header>
    <main class="container">
      <slot />
    </main>
    <footer class="site-footer">
      <div class="container">
        Community-maintained reference for computational genome editing tools. See
        <a href="https://github.com/mme-3/genome-editing-tools-db/blob/main/CONTRIBUTING.md">CONTRIBUTING.md</a>
        to add a tool.
      </div>
    </footer>
  </body>
</html>

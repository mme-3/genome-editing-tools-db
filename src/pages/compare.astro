---
import Base from '../layouts/Base.astro';

const base = import.meta.env.BASE_URL;
---

<Base title="Compare tools" description="Side-by-side comparison of computational genome editing tools.">
  <h1>Compare tools</h1>
  <p>Pick up to four tools to compare side by side. Selections made on the <a href={`${base}tools/`}>Browse</a> page carry over here automatically.</p>

  <div class="add-tool">
    <label for="add-tool-select">Add a tool:</label>
    <select id="add-tool-select"><option value="">Choose a tool...</option></select>
  </div>

  <p id="compare-empty" class="compare-empty">No tools selected yet.</p>
  <div id="compare-table-wrap"></div>
</Base>

<style>
  .add-tool {
    margin: 1rem 0 1.5rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .add-tool select {
    padding: 0.4rem 0.6rem;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
  }
  .compare-empty {
    color: var(--color-text-muted);
  }
  :global(.compare-table) {
    width: 100%;
    border-collapse: collapse;
  }
  :global(.compare-table th),
  :global(.compare-table td) {
    border: 1px solid var(--color-border);
    padding: 0.6rem;
    vertical-align: top;
    text-align: left;
    min-width: 12rem;
  }
  :global(.compare-table th.row-label) {
    background: var(--color-bg-subtle);
    width: 10rem;
    min-width: 10rem;
  }
  :global(.compare-table td ul) {
    margin: 0;
    padding-left: 1.1rem;
  }
  :global(.remove-col) {
    margin-left: 0.5rem;
    font-size: 0.8rem;
    cursor: pointer;
    background: none;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    padding: 0.1rem 0.4rem;
  }
</style>

<script define:vars={{ base }}>
  const MAX_COMPARE = 4;

  function getIdsFromUrl() {
    const params = new URLSearchParams(location.search);
    const raw = params.get('ids');
    return raw ? raw.split(',').filter(Boolean) : [];
  }

  function setIdsInUrl(ids) {
    const url = new URL(location.href);
    if (ids.length > 0) {
      url.searchParams.set('ids', ids.join(','));
    } else {
      url.searchParams.delete('ids');
    }
    history.replaceState(null, '', url);
  }

  function list(items) {
    if (!items || items.length === 0) return '—';
    const ul = document.createElement('ul');
    for (const item of items) {
      const li = document.createElement('li');
      li.textContent = item;
      ul.appendChild(li);
    }
    return ul;
  }

  function cell(value) {
    const td = document.createElement('td');
    if (value instanceof Node) {
      td.appendChild(value);
    } else {
      td.textContent = value ?? '—';
    }
    return td;
  }

  async function init() {
    const res = await fetch(`${base}tools.json`);
    const tools = await res.json();
    const byId = new Map(tools.map((t) => [t.id, t]));

    const select = document.getElementById('add-tool-select');
    for (const tool of tools) {
      const option = document.createElement('option');
      option.value = tool.id;
      option.textContent = tool.name;
      select.appendChild(option);
    }

    function render() {
      const ids = getIdsFromUrl().filter((id) => byId.has(id));
      const wrap = document.getElementById('compare-table-wrap');
      const empty = document.getElementById('compare-empty');
      wrap.innerHTML = '';

      if (ids.length === 0) {
        empty.hidden = false;
        return;
      }
      empty.hidden = true;

      const selectedTools = ids.map((id) => byId.get(id));
      const rows = [
        ['Category', (t) => t.category],
        ['Editing modality', (t) => t.supported_editors.join(', ')],
        ['Platform', (t) => t.platform.join(', ')],
        ['License', (t) => t.license],
        ['Maintenance status', (t) => t.maintenance_status],
        ['AI-enabled', (t) => (t.ai_enabled ? 'Yes' : 'No')],
        ['Description', (t) => t.description],
        ['Strengths', (t) => list(t.strengths)],
        ['Weaknesses', (t) => list(t.weaknesses)],
        ['Ideal use cases', (t) => list(t.ideal_use_cases)],
        ['Limitations', (t) => list(t.limitations)],
        ['Publication', (t) => (t.publication?.title ? `${t.publication.title} (${t.publication.year ?? 'n.d.'})` : '—')],
      ];

      const table = document.createElement('table');
      table.className = 'compare-table';

      const thead = document.createElement('thead');
      const headRow = document.createElement('tr');
      headRow.appendChild(document.createElement('th'));
      for (const tool of selectedTools) {
        const th = document.createElement('th');
        const link = document.createElement('a');
        link.href = `${base}tools/${tool.id}/`;
        link.textContent = tool.name;
        th.appendChild(link);
        const removeBtn = document.createElement('button');
        removeBtn.textContent = '×';
        removeBtn.className = 'remove-col';
        removeBtn.type = 'button';
        removeBtn.addEventListener('click', () => {
          setIdsInUrl(ids.filter((id) => id !== tool.id));
          render();
        });
        th.appendChild(removeBtn);
        headRow.appendChild(th);
      }
      thead.appendChild(headRow);
      table.appendChild(thead);

      const tbody = document.createElement('tbody');
      for (const [label, getValue] of rows) {
        const tr = document.createElement('tr');
        const th = document.createElement('th');
        th.className = 'row-label';
        th.textContent = label;
        tr.appendChild(th);
        for (const tool of selectedTools) {
          tr.appendChild(cell(getValue(tool)));
        }
        tbody.appendChild(tr);
      }
      table.appendChild(tbody);
      wrap.appendChild(table);
    }

    select.addEventListener('change', () => {
      const id = select.value;
      if (!id) return;
      const ids = getIdsFromUrl();
      if (ids.includes(id)) {
        select.value = '';
        return;
      }
      if (ids.length >= MAX_COMPARE) {
        alert(`You can compare up to ${MAX_COMPARE} tools at a time.`);
        select.value = '';
        return;
      }
      setIdsInUrl([...ids, id]);
      select.value = '';
      render();
    });

    render();
  }

  document.addEventListener('DOMContentLoaded', init);
</script>
